{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Access UK feature record",
  "type": "object",
  "required": ["id", "name", "tool", "status", "priority", "risk_level", "source_needs", "mvp"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "tool": { "type": "string" },
    "status": { "enum": ["planned", "in-progress", "shipped", "paused"] },
    "priority": { "enum": ["low", "medium", "high"] },
    "risk_level": { "enum": ["low", "medium", "high"] },
    "source_needs": { "type": "string" },
    "mvp": { "type": "string" }
  }
}
