{
  "name": "open-access-uk-suite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "verify": "node scripts/verify-suite.mjs",
    "sync:metadata": "node scripts/sync-static-metadata.mjs",
    "validate:features": "node scripts/validate-features.mjs",
    "validate:deadlines": "node scripts/validate-deadline-rules.mjs",
    "validate:shared": "node --test shared/privacy/local-storage.test.mjs shared/exports/index.test.mjs shared/deadlines/index.test.mjs shared/calendar/ics.test.mjs shared/readability/index.test.mjs shared/search/index.test.mjs shared/evidence/index.test.mjs shared/collections/index.test.mjs",
    "validate:sources": "node scripts/validate-sources.mjs",
    "validate:repositories": "node scripts/validate-repositories.mjs",
    "quality:static": "node scripts/static-quality.mjs",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "lint": "npm run quality:static",
    "lighthouse": "lhci autorun",
    "test:e2e": "playwright test -c open-access-uk-site/playwright.config.js open-access-uk-site/tests/e2e",
    "test:a11y": "playwright test -c open-access-uk-site/playwright.config.js open-access-uk-site/tests/a11y"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.45.0",
    "http-server": "^14.1.1",
    "prettier": "^3.3.3"
  },
  "license": "MIT"
}
