{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "node scripts/serve-static.mjs open-access-uk-site 4180",
      "startServerReadyPattern": "Open Access UK static server ready",
      "url": ["http://127.0.0.1:4180/"],
      "settings": {
        "budgetPath": "./.lighthouse/budget.json",
        "chromeFlags": "--headless=new --no-sandbox",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 650000 }],
        "unused-css-rules": ["warn", { "maxLength": 1 }],
        "unused-javascript": ["warn", { "maxLength": 1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
